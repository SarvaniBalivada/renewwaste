{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "buildCommand": "npm run build",
        "outputDirectory": "build"
      }
    },
    {
      "src": "api/items.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/auth.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/orders.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/feedback.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/items",
      "dest": "/api/items.js"
    },
    {
      "src": "/api/auth/signup",
      "dest": "/api/auth.js"
    },
    {
      "src": "/api/auth/login",
      "dest": "/api/auth.js"
    },
    {
      "src": "/api/orders",
      "dest": "/api/orders.js"
    },
    {
      "src": "/api/feedback",
      "dest": "/api/feedback.js"
    },
    {
      "src": "/static/(.*)",
      "dest": "/build/static/$1"
    },
    {
      "src": "/manifest.json",
      "dest": "/build/manifest.json"
    },
    {
      "src": "/favicon.ico",
      "dest": "/build/favicon.ico"
    },
    {
      "src": "/(.*)",
      "dest": "/build/index.html"
    }
  ]
}
